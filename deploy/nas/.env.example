# Required: absolute path on the NAS where downloads and MeTube state are stored.
METUBE_DOWNLOAD_DIR=/volume1/downloads/metube

# Match the owner of METUBE_DOWNLOAD_DIR (`id -u` and `id -g` on the NAS).
METUBE_PUID=1000
METUBE_PGID=1000

# Web UI listener. Set METUBE_BIND_ADDRESS to the NAS LAN address to restrict it.
METUBE_BIND_ADDRESS=0.0.0.0
METUBE_PORT=8081

# Optional proxy reachable from the NAS Docker network. Leave blank when unnecessary.
# For a proxy on another LAN machine, enable LAN access in the proxy application.
METUBE_HTTP_PROXY=
METUBE_HTTPS_PROXY=

# Keep Bilibili direct while other sites use the proxy.
METUBE_NO_PROXY=localhost,127.0.0.1,bilibili.com,.bilibili.com,bilivideo.com,.bilivideo.com

# Optional global yt-dlp API options, encoded as one-line JSON.
METUBE_YTDL_OPTIONS={}

# Upgrade yt-dlp nightly on startup and restart for an update at this local time.
METUBE_YTDL_NIGHTLY_UPDATE_TIME=04:00
